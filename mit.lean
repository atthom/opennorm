-- ── Core Consistency ──────────────────────────────────────────────────────

-- Nothing can be simultaneously permitted and forbidden
axiom deontic_consistency (a : Actor) (x : Action) :
  ¬(Permitted a x ∧ Forbidden a x)

-- Obligation implies permission
axiom obligation_permits (a : Actor) (x : Action) :
  Obligated a x → Permitted a x

-- ── Defeasibility Structure ──────────────────────────────────────────────

-- A rule in a defeasible reasoning chain
structure Rule (α β : Type) where
  id : String
  applies : α → β → Bool
  permitted : Bool
  priority : Nat

-- Find the winning rule: highest priority rule that applies
def winning_rule {α β : Type} (rules : List (Rule α β)) (a : α) (x : β) : Option (Rule α β) :=
  (rules.filter (fun r => r.applies a x)).foldl
    (fun acc r => match acc with
      | none => some r
      | some current => if r.priority > current.priority then some r else some current)
    none

-- Determine permission via defeasible reasoning
def defeasible_permitted {α β : Type} (rules : List (Rule α β)) (a : α) (x : β) : Bool :=
  match winning_rule rules a x with
  | some r => r.permitted
  | none => false


