-- Action: any act that can be permitted, obligated, or forbidden
axiom Action : Type

-- Set type (simplified for licensing)
def Set (α : Type) : Type := α → Prop

-- Subset relation for sets
def Set.subset {α : Type} (s1 s2 : Set α) : Prop :=
  ∀ x, s1 x → s2 x

-- Enable ⊆ notation
instance {α : Type} : HasSubset (Set α) where
  Subset := Set.subset

-- ── Deontic Modalities ────────────────────────────────────────────────────

axiom Permitted (actor : Actor) (action : Action) : Prop

axiom Obligated (actor : Actor) (action : Action) : Prop

